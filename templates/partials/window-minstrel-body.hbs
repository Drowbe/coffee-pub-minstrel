<div class="minstrel-body">
    {{#if isDashboard}}
    <section class="minstrel-grid minstrel-dashboard-grid">
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Now Playing</h2>
            </header>
            <div class="minstrel-state-list">
                <div class="minstrel-state-row">
                    <span class="minstrel-state-label">Active Scene</span>
                    <span class="minstrel-state-value">{{#if dashboard.activeSoundScene}}{{dashboard.activeSoundScene.name}}{{else}}None{{/if}}</span>
                </div>
                <div class="minstrel-state-row">
                    <span class="minstrel-state-label">Music</span>
                    <span class="minstrel-state-value">{{#if dashboard.nowPlaying.music}}{{dashboard.nowPlaying.music.soundName}}{{else}}None{{/if}}</span>
                </div>
                <div class="minstrel-state-row">
                    <span class="minstrel-state-label">Ambient Layers</span>
                    <span class="minstrel-state-value">{{dashboard.nowPlaying.ambientTracks.length}}</span>
                </div>
            </div>
            <div class="minstrel-tag-list">
                {{#each dashboard.nowPlaying.activeTracks}}
                <span class="minstrel-tag">{{this.soundName}}</span>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Recent Tracks</h2>
            </header>
            <div class="minstrel-list">
                {{#each dashboard.recents}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.soundName}}</div>
                        <div class="minstrel-list-meta">{{this.playlistName}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="playTrack" data-value="{{this.playlistId}}::{{this.soundId}}"><i class="fa-solid fa-play"></i><span>Play</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No recent tracks yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Favorite Tracks</h2>
            </header>
            <div class="minstrel-list">
                {{#each dashboard.favorites}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.soundName}}</div>
                        <div class="minstrel-list-meta">{{this.playlistName}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="playTrack" data-value="{{this.playlistId}}::{{this.soundId}}"><i class="fa-solid fa-play"></i><span>Play</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No favorite tracks saved.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Recent Cues</h2>
            </header>
            <div class="minstrel-list">
                {{#each dashboard.recentCues}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.category}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="triggerCue" data-value="{{this.id}}"><i class="{{this.icon}}"></i><span>Trigger</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No cues triggered in this session.</p>
                {{/each}}
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isPlaylists}}
    <section class="minstrel-stack">
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Playlist Filters</h2>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="clearPlaylistFilters"><i class="fa-solid fa-broom-wide"></i><span>Clear</span></button>
                </div>
            </header>
            <div class="minstrel-form-grid">
                <label class="minstrel-form-span-2">Search
                    <input type="text" id="minstrel-playlist-search" value="{{playlistSearch}}" placeholder="Type 3+ characters to search tracks, playlists, paths, or channels" />
                </label>
                <div class="minstrel-form-span-2">
                    <div class="minstrel-subheader">Channel</div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-filter {{#if isPlaylistChannelAll}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="all"><span>All</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-filter {{#if isPlaylistChannelMusic}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="music"><span>Music</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-filter {{#if isPlaylistChannelAmbient}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="ambient"><span>Environment</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-filter {{#if isPlaylistChannelCue}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="cue"><span>Interface</span></button>
                    </div>
                </div>
                <div class="minstrel-form-span-2">
                    <div class="minstrel-subheader">Status</div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-filter {{#if isPlaylistStatusAll}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="all"><span>All</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-filter {{#if isPlaylistStatusPlaying}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="playing"><span>Playing</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-filter {{#if isPlaylistStatusFavorites}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="favorites"><span>Favorites</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-filter {{#if isPlaylistStatusRecents}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="recents"><span>Recents</span></button>
                    </div>
                </div>
            </div>
        </article>
        {{#each playlistSummary}}
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>{{this.name}}</h2>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="skipPlaylist" data-value="{{this.id}}"><i class="fa-solid fa-forward-step"></i><span>Skip</span></button>
                </div>
            </header>
            <div class="minstrel-list">
                {{#each this.sounds}}
                <div class="minstrel-list-row minstrel-track-row">
                    <div class="minstrel-track-main">
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{#if this.playing}}Playing{{else}}Idle{{/if}} · {{this.channel}} · {{this.path}}</div>
                    </div>
                    <div class="minstrel-track-volume">
                        <input type="number" min="0" max="1" step="0.05" value="{{this.volume}}" data-track-volume="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}" />
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="applyTrackVolume" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-sliders"></i><span>Apply</span></button>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="playTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-play"></i><span>Play</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="pauseTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-pause"></i><span>Pause</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="resumeTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-play-circle"></i><span>Resume</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="stopTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-stop"></i><span>Stop</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="toggleFavoriteTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid {{#if this.favorite}}fa-star{{else}}fa-star-half-stroke{{/if}}"></i><span>{{#if this.favorite}}Unfavorite{{else}}Favorite{{/if}}</span></button>
                    </div>
                </div>
                {{/each}}
            </div>
        </article>
        {{/each}}
    </section>
    {{/if}}

    {{#if isSoundScenes}}
    <section class="minstrel-scenes-workspace">
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Scenes</h2>
                <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="newSoundScene"><i class="fa-solid fa-plus"></i><span>New</span></button>
            </header>
            <div class="minstrel-list">
                {{#each soundScenes}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.layers.length}} layers</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="selectSoundScene" data-value="{{this.id}}"><i class="fa-solid fa-pen"></i><span>Edit</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="playSoundScene" data-value="{{this.id}}"><i class="fa-solid fa-play"></i><span>Play</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No sound scenes saved yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Sound Selector</h2>
            </header>
            <div class="minstrel-stack">
                <div class="minstrel-selector-section">
                    <div class="minstrel-subheader">Music</div>
                    <div class="minstrel-selector-list">
                        {{#each soundSelectorMusicOptions}}
                        <div class="minstrel-selector-row">
                            <div>
                                <div class="minstrel-list-title">{{this.label}}</div>
                            </div>
                            <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="addSceneLayer" data-layer-type="music" data-value="{{this.value}}"><i class="fa-solid fa-plus"></i><span>Add</span></button>
                        </div>
                        {{/each}}
                    </div>
                </div>
                <div class="minstrel-selector-section">
                    <div class="minstrel-subheader">Environment</div>
                    <div class="minstrel-selector-list">
                        {{#each soundSelectorAmbientOptions}}
                        <div class="minstrel-selector-row">
                            <div>
                                <div class="minstrel-list-title">{{this.label}}</div>
                            </div>
                            <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="addSceneLayer" data-layer-type="environment" data-value="{{this.value}}"><i class="fa-solid fa-plus"></i><span>Add</span></button>
                        </div>
                        {{/each}}
                    </div>
                </div>
                <div class="minstrel-selector-section">
                    <div class="minstrel-subheader">Scheduled One-Shots</div>
                    <div class="minstrel-selector-list">
                        {{#each soundSelectorOneShotOptions}}
                        <div class="minstrel-selector-row">
                            <div>
                                <div class="minstrel-list-title">{{this.label}}</div>
                            </div>
                            <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="addSceneLayer" data-layer-type="scheduled-one-shot" data-value="{{this.value}}"><i class="fa-solid fa-plus"></i><span>Add</span></button>
                        </div>
                        {{/each}}
                    </div>
                </div>
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Scene Details</h2>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="saveSoundScene"><i class="fa-solid fa-floppy-disk"></i><span>Save</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="playSoundScene" data-value="{{selectedSoundScene.id}}"><i class="fa-solid fa-play"></i><span>Play</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="stopSoundScene"><i class="fa-solid fa-stop"></i><span>Stop</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-danger" data-action="deleteSoundScene"><i class="fa-solid fa-trash"></i><span>Delete</span></button>
                </div>
            </header>
            <div class="minstrel-stack">
                <div class="minstrel-form-grid">
                    <label>Name<input type="text" id="sound-scene-name" value="{{selectedSoundScene.name}}" /></label>
                    <label>Tags<input type="text" id="sound-scene-tags" value="{{selectedSoundSceneTagText}}" placeholder="combat, tavern, rain" /></label>
                    <label class="minstrel-form-span-2">Description<textarea id="sound-scene-description">{{selectedSoundScene.description}}</textarea></label>
                    <label>Default Fade In<input type="number" id="sound-scene-default-fade-in" min="0" max="30" step="1" value="{{selectedSoundScene.fadeIn}}" /></label>
                    <label>Default Fade Out<input type="number" id="sound-scene-default-fade-out" min="0" max="30" step="1" value="{{selectedSoundScene.fadeOut}}" /></label>
                    <label class="minstrel-checkbox"><input type="checkbox" id="sound-scene-restore" {{#if selectedSoundScene.restorePreviousOnExit}}checked{{/if}} /> Restore previous on exit</label>
                    <label class="minstrel-checkbox"><input type="checkbox" id="sound-scene-enabled" {{#if selectedSoundScene.enabled}}checked{{/if}} /> Enabled</label>
                    <label class="minstrel-checkbox"><input type="checkbox" id="sound-scene-favorite" {{#if selectedSoundScene.favorite}}checked{{/if}} /> Favorite</label>
                </div>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">Music</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneMusicLayers}}
                        <div class="minstrel-layer-card" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-card-header">
                                <div>
                                    <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                    <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                </div>
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-danger" data-action="removeSceneLayer" data-value="{{this.id}}"><i class="fa-solid fa-trash"></i><span>Remove</span></button>
                            </div>
                            <div class="minstrel-scene-layer-grid">
                                <label>Volume<input type="number" min="0" max="1" step="0.05" value="{{this.volume}}" data-scene-layer-field="volume" /></label>
                                <label>Start Delay (ms)<input type="number" min="0" max="600000" step="1000" value="{{this.startDelayMs}}" data-scene-layer-field="startDelayMs" /></label>
                                <label>Fade In<input type="number" min="0" max="30" step="1" value="{{this.fadeIn}}" data-scene-layer-field="fadeIn" /></label>
                                <label>Fade Out<input type="number" min="0" max="30" step="1" value="{{this.fadeOut}}" data-scene-layer-field="fadeOut" /></label>
                                <label>Loop<select data-scene-layer-field="loopMode"><option value="inherit">Inherit</option></select></label>
                                <label class="minstrel-checkbox"><input type="checkbox" data-scene-layer-field="enabled" {{#if this.enabled}}checked{{/if}} /> Enabled</label>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No music layer yet.</p>
                        {{/each}}
                    </div>
                </div>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">Environment</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneEnvironmentLayers}}
                        <div class="minstrel-layer-card" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-card-header">
                                <div>
                                    <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                    <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                </div>
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-danger" data-action="removeSceneLayer" data-value="{{this.id}}"><i class="fa-solid fa-trash"></i><span>Remove</span></button>
                            </div>
                            <div class="minstrel-scene-layer-grid">
                                <label>Volume<input type="number" min="0" max="1" step="0.05" value="{{this.volume}}" data-scene-layer-field="volume" /></label>
                                <label>Start Delay (ms)<input type="number" min="0" max="600000" step="1000" value="{{this.startDelayMs}}" data-scene-layer-field="startDelayMs" /></label>
                                <label>Fade In<input type="number" min="0" max="30" step="1" value="{{this.fadeIn}}" data-scene-layer-field="fadeIn" /></label>
                                <label>Fade Out<input type="number" min="0" max="30" step="1" value="{{this.fadeOut}}" data-scene-layer-field="fadeOut" /></label>
                                <label>Loop<select data-scene-layer-field="loopMode"><option value="inherit">Inherit</option></select></label>
                                <label class="minstrel-checkbox"><input type="checkbox" data-scene-layer-field="enabled" {{#if this.enabled}}checked{{/if}} /> Enabled</label>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No environment layers yet.</p>
                        {{/each}}
                    </div>
                </div>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">Scheduled One-Shots</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneScheduledLayers}}
                        <div class="minstrel-layer-card" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-card-header">
                                <div>
                                    <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                    <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                </div>
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-danger" data-action="removeSceneLayer" data-value="{{this.id}}"><i class="fa-solid fa-trash"></i><span>Remove</span></button>
                            </div>
                            <div class="minstrel-scene-layer-grid">
                                <label>Volume<input type="number" min="0" max="1" step="0.05" value="{{this.volume}}" data-scene-layer-field="volume" /></label>
                                <label>Start Delay (ms)<input type="number" min="0" max="600000" step="1000" value="{{this.startDelayMs}}" data-scene-layer-field="startDelayMs" /></label>
                                <label>Fade In<input type="number" min="0" max="30" step="1" value="{{this.fadeIn}}" data-scene-layer-field="fadeIn" /></label>
                                <label>Fade Out<input type="number" min="0" max="30" step="1" value="{{this.fadeOut}}" data-scene-layer-field="fadeOut" /></label>
                                <label>Frequency (sec)<input type="number" min="1" max="3600" step="1" value="{{this.frequencySeconds}}" data-scene-layer-field="frequencySeconds" /></label>
                                <label>Loop<select data-scene-layer-field="loopMode"><option value="repeat">Repeat</option></select></label>
                                <label class="minstrel-checkbox"><input type="checkbox" data-scene-layer-field="enabled" {{#if this.enabled}}checked{{/if}} /> Enabled</label>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No scheduled one-shots yet.</p>
                        {{/each}}
                    </div>
                </div>
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isCues}}
    <section class="minstrel-editor-grid">
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Cues</h2>
                <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="newCue"><i class="fa-solid fa-plus"></i><span>New</span></button>
            </header>
            <div class="minstrel-cue-grid">
                {{#each cues}}
                <button type="button" class="minstrel-cue-card" data-action="triggerCue" data-value="{{this.id}}">
                    <i class="{{this.icon}}"></i>
                    <span>{{this.name}}</span>
                </button>
                {{else}}
                <p class="minstrel-empty">No cues configured yet.</p>
                {{/each}}
            </div>
            <div class="minstrel-list">
                {{#each cues}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.category}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="selectCue" data-value="{{this.id}}"><i class="fa-solid fa-pen"></i><span>Edit</span></button>
                    </div>
                </div>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Cue Editor</h2>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="saveCue"><i class="fa-solid fa-floppy-disk"></i><span>Save</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="triggerCue"><i class="fa-solid fa-bolt"></i><span>Trigger</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-danger" data-action="deleteCue"><i class="fa-solid fa-trash"></i><span>Delete</span></button>
                </div>
            </header>
            <div class="minstrel-form-grid">
                <label>Name<input type="text" id="cue-name" value="{{selectedCue.name}}" /></label>
                <label>Category<input type="text" id="cue-category" value="{{selectedCue.category}}" /></label>
                <label>Icon<input type="text" id="cue-icon" value="{{selectedCue.icon}}" placeholder="fa-solid fa-bell" /></label>
                <label>Track
                    <select id="cue-track">
                        <option value="">Select a track</option>
                        {{#each cueTrackOptions}}
                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                        {{/each}}
                    </select>
                </label>
                <label>Volume<input type="number" id="cue-volume" min="0" max="1" step="0.05" value="{{selectedCue.volume}}" /></label>
                <label>Cooldown (seconds)<input type="number" id="cue-cooldown" min="0" max="120" step="1" value="{{selectedCue.cooldown}}" /></label>
                <label class="minstrel-checkbox"><input type="checkbox" id="cue-duck-others" {{#if selectedCue.duckOthers}}checked{{/if}} /> Duck music and ambience</label>
                <label class="minstrel-checkbox"><input type="checkbox" id="cue-stop-on-scene-change" {{#if selectedCue.stopOnSceneChange}}checked{{/if}} /> Stop on scene change</label>
                <label class="minstrel-checkbox"><input type="checkbox" id="cue-favorite" {{#if selectedCue.favorite}}checked{{/if}} /> Favorite</label>
                <label class="minstrel-checkbox"><input type="checkbox" id="cue-enabled" {{#if selectedCue.enabled}}checked{{/if}} /> Enabled</label>
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isAutomation}}
    <section class="minstrel-editor-grid">
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Automation Rules</h2>
                <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="newRule"><i class="fa-solid fa-plus"></i><span>New</span></button>
            </header>
            <div class="minstrel-list">
                {{#each rules}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.eventType}} · Priority {{this.priority}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="selectRule" data-value="{{this.id}}"><i class="fa-solid fa-pen"></i><span>Edit</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="runRule" data-value="{{this.id}}"><i class="fa-solid fa-play"></i><span>Run</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No automation rules saved yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h2>Rule Editor</h2>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="saveRule"><i class="fa-solid fa-floppy-disk"></i><span>Save</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="runRule"><i class="fa-solid fa-play"></i><span>Run</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-danger" data-action="deleteRule"><i class="fa-solid fa-trash"></i><span>Delete</span></button>
                </div>
            </header>
            <div class="minstrel-form-grid">
                <label>Name<input type="text" id="rule-name" value="{{selectedRule.name}}" /></label>
                <label>Event Type
                    <select id="rule-event-type">
                        {{#each ruleEventOptions}}
                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                        {{/each}}
                    </select>
                </label>
                <label>Sound Scene
                    <select id="rule-sound-scene">
                        <option value="">None</option>
                        {{#each ruleSoundSceneOptions}}
                        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
                        {{/each}}
                    </select>
                </label>
                <label>Priority<input type="number" id="rule-priority" min="-100" max="100" step="1" value="{{selectedRule.priority}}" /></label>
                <label>Delay (ms)<input type="number" id="rule-delay-ms" min="0" max="30000" step="250" value="{{selectedRule.delayMs}}" /></label>
                <label class="minstrel-checkbox"><input type="checkbox" id="rule-restore" {{#if selectedRule.restorePreviousOnExit}}checked{{/if}} /> Restore previous audio on combat end</label>
                <label class="minstrel-checkbox"><input type="checkbox" id="rule-enabled" {{#if selectedRule.enabled}}checked{{/if}} /> Enabled</label>
            </div>
        </article>
    </section>
    {{/if}}
</div>
