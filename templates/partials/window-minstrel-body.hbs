                                    </div>
                                </div>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No music track yet.</p>
                        {{/each}}
                    </div>
                </div>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">Environment</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneEnvironmentLayers}}
                        <div class="minstrel-layer-card minstrel-card-environment" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-row minstrel-layer-type-row">
                                <div class="minstrel-layer-type-icon" aria-hidden="true">
                                    <i class="fa-solid fa-waveform"></i>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-details">
                                    <div class="minstrel-layer-main">
                                        <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                        <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-audio">
                                    <label class="minstrel-layer-slider" title="Volume" aria-label="Volume">
                                        <i class="fa-solid fa-volume-high"></i>
                                        <input type="range" min="0" max="100" step="1" value="{{this.volumePercent}}" data-scene-layer-field="volume" />
                                        <span>{{this.volumePercent}}%</span>
                                    </label>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-timeline">
                                    <div class="minstrel-layer-timeline-slot {{#if this.timelineIsActive}}is-active{{/if}} {{#if this.timelineSingleEvent}}is-event-only{{/if}}" title="{{this.timelineTooltip}}">
                                        <span class="minstrel-layer-timeline-start-marker"></span>
                                        {{#if this.timelineShowBar}}
                                        <div class="minstrel-layer-timeline-bar" style="width: {{this.timelineWidthPercent}}%;"></div>
                                        {{/if}}
                                        {{#each this.timelineRepeatSegments}}
                                        <div class="minstrel-layer-timeline-repeat-bar" style="left: {{this.leftPercent}}%; width: {{this.widthPercent}}%;"></div>
                                        {{/each}}
                                        {{#if this.timelineSingleEvent}}
                                        <span class="minstrel-layer-timeline-event-marker"></span>
                                        {{/if}}
                                        {{#each this.timelineRepeatMarkers}}
                                        <span class="minstrel-layer-timeline-repeat-marker" style="left: {{this}}%;"></span>
                                        {{/each}}
                                        <span class="minstrel-layer-timeline-label">{{this.durationLabel}}</span>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-actions">
                                    <div class="minstrel-layer-controls">
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Loop playback">
                                        <input type="checkbox" data-scene-layer-field="loopMode" {{#if this.loopEnabled}}checked{{/if}} />
                                        <i class="fa-solid fa-repeat"></i>
                                    </label>
                                    <label class="minstrel-layer-textfield" title="Delay before playback in seconds" aria-label="Delay before playback in seconds">
                                        <input type="number" min="0" max="3600" step="1" value="{{this.startDelaySeconds}}" data-scene-layer-field="startDelaySeconds" />
                                    </label>
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Track enabled">
                                        <input type="checkbox" data-scene-layer-field="enabled" {{#if this.enabled}}checked{{/if}} />
                                        <i class="fa-solid fa-power-off"></i>
                                    </label>
                                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="removeSceneLayer" data-value="{{this.id}}" title="Remove track" aria-label="Remove track"><i class="fa-solid fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No environment tracks yet.</p>
                        {{/each}}
                    </div>
                </div>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">One-Shots</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneScheduledLayers}}
                        <div class="minstrel-layer-card minstrel-card-oneshot" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-row minstrel-layer-type-row">
                                <div class="minstrel-layer-type-icon" aria-hidden="true">
                                    <i class="fa-solid fa-volume"></i>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-details">
                                    <div class="minstrel-layer-main">
                                        <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                        <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-audio">
                                    <label class="minstrel-layer-slider" title="Volume" aria-label="Volume">
                                        <i class="fa-solid fa-volume-high"></i>
                                        <input type="range" min="0" max="100" step="1" value="{{this.volumePercent}}" data-scene-layer-field="volume" />
                                        <span>{{this.volumePercent}}%</span>
                                    </label>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-timeline">
                                    <div class="minstrel-layer-timeline-slot {{#if this.timelineIsActive}}is-active{{/if}} {{#if this.timelineSingleEvent}}is-event-only{{/if}}" title="{{this.timelineTooltip}}">
                                        <span class="minstrel-layer-timeline-start-marker"></span>
                                        {{#if this.timelineShowBar}}
                                        <div class="minstrel-layer-timeline-bar" style="width: {{this.timelineWidthPercent}}%;"></div>
                                        {{/if}}
                                        {{#each this.timelineRepeatSegments}}
                                        <div class="minstrel-layer-timeline-repeat-bar" style="left: {{this.leftPercent}}%; width: {{this.widthPercent}}%;"></div>
                                        {{/each}}
                                        {{#if this.timelineSingleEvent}}
                                        <span class="minstrel-layer-timeline-event-marker"></span>
                                        {{/if}}
                                        {{#each this.timelineRepeatMarkers}}
                                        <span class="minstrel-layer-timeline-repeat-marker" style="left: {{this}}%;"></span>
                                        {{/each}}
                                        <span class="minstrel-layer-timeline-label">{{this.durationLabel}}</span>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-actions">
                                    <div class="minstrel-layer-controls">
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Loop playback">
                                        <input type="checkbox" data-scene-layer-field="loopMode" {{#if this.loopEnabled}}checked{{/if}} />
                                        <i class="fa-solid fa-repeat"></i>
                                    </label>
                                    <label class="minstrel-layer-textfield" data-scene-layer-frequency title="{{#if this.loopEnabled}}Delay and repeat interval in seconds{{else}}Delay before playback in seconds{{/if}}" aria-label="{{#if this.loopEnabled}}Delay and repeat interval in seconds{{else}}Delay before playback in seconds{{/if}}">
                                        <input type="number" min="1" max="3600" step="1" value="{{this.frequencySeconds}}" data-scene-layer-field="frequencySeconds" />
                                    </label>
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Track enabled">
                                        <input type="checkbox" data-scene-layer-field="enabled" {{#if this.enabled}}checked{{/if}} />
                                        <i class="fa-solid fa-power-off"></i>
                                    </label>
                                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="removeSceneLayer" data-value="{{this.id}}" title="Remove track" aria-label="Remove track"><i class="fa-solid fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No scheduled one-shot tracks yet.</p>
                        {{/each}}
                    </div>
                </div>
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isCues}}
    <section class="minstrel-cues-workspace">
        <article class="minstrel-panel-card minstrel-cues-browser-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Cue Sheets</h3>
                <button type="button" class="minstrel-icon-action" data-action="newCue" title="New Cue" aria-label="New Cue"><i class="fa-solid fa-plus"></i></button>
            </header>
            <div class="minstrel-column-list">
                {{#each cueGroups}}
                <section class="minstrel-cue-sheet">
                    <header class="minstrel-section-header">
                        <h4 class="minstrel-section-title">{{this.name}}</h4>
                    </header>
                    <div class="minstrel-cue-grid">
                        {{#each this.cues}}
                        <div class="minstrel-cue-browser-card {{#if this.isSelected}}is-selected{{/if}}" style="{{this.cardStyle}}">
                            <button type="button" class="minstrel-cue-card" data-action="triggerCue" data-value="{{this.id}}">
                                <i class="{{this.icon}}"></i>
                                <span>{{this.name}}</span>
                                <small>{{#if this.track}}{{this.track.soundName}}{{else}}No track assigned{{/if}}</small>
                            </button>
                            <button type="button" class="minstrel-icon-action minstrel-cue-card-edit {{#if this.isSelected}}is-active{{/if}}" data-action="selectCue" data-value="{{this.id}}" title="Edit Cue" aria-label="Edit Cue"><i class="fa-solid fa-feather-pointed"></i></button>
                        </div>
                        {{/each}}
                    </div>
                </section>
                {{else}}
                <p class="minstrel-empty">No cues configured yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card minstrel-cue-editor-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Cue Editor</h3>
                <div class="minstrel-row-actions">
                    <label class="minstrel-icon-toggle" title="Duck music and ambience">
                        <input type="checkbox" id="cue-duck-others" {{#if selectedCue.duckOthers}}checked{{/if}} />
                        <i class="fa-solid fa-wave-pulse"></i>
                    </label>
                    <label class="minstrel-icon-toggle" title="Stop on scene change">
                        <input type="checkbox" id="cue-stop-on-scene-change" {{#if selectedCue.stopOnSceneChange}}checked{{/if}} />
                        <i class="fa-solid fa-route"></i>
                    </label>
                    <label class="minstrel-icon-toggle" title="Favorite cue">
                        <input type="checkbox" id="cue-favorite" {{#if selectedCue.favorite}}checked{{/if}} />
                        <i class="fa-solid fa-heart"></i>
                    </label>
                    <label class="minstrel-icon-toggle" title="Cue enabled">
                        <input type="checkbox" id="cue-enabled" {{#if selectedCue.enabled}}checked{{/if}} />
                        <i class="fa-solid fa-power-off"></i>
                    </label>
                    <button type="button" class="minstrel-icon-action" data-action="saveCue" title="Save Cue" aria-label="Save Cue"><i class="fa-solid fa-floppy-disk"></i></button>
                    <button type="button" class="minstrel-icon-action" data-action="triggerCue" title="Trigger Cue" aria-label="Trigger Cue"><i class="fa-solid fa-bolt"></i></button>
                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="deleteCue" title="Delete Cue" aria-label="Delete Cue"><i class="fa-solid fa-trash"></i></button>
                </div>
            </header>
            <div class="minstrel-cue-editor-shell">
                <div class="minstrel-cue-editor-hero">
                    <div class="minstrel-cue-editor-icon" {{#if selectedCue.tintColor}}style="background: {{selectedCue.tintColor}};"{{/if}}>
                        <i class="{{selectedCue.icon}}"></i>
                    </div>
                    <div class="minstrel-cue-editor-copy">
                        <div class="minstrel-list-title">{{#if selectedCue.name}}{{selectedCue.name}}{{else}}New Cue{{/if}}</div>
                        <div class="minstrel-list-meta">{{#if selectedCue.category}}{{selectedCue.category}}{{else}}General{{/if}} Cue Sheet</div>
                    </div>
                </div>
                <div class="minstrel-form-grid minstrel-cue-form-grid">
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Cue Name</span>
                        <input type="text" id="cue-name" value="{{selectedCue.name}}" />
                    </label>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Cue Sheet</span>
                        <input type="text" id="cue-category" value="{{selectedCue.category}}" list="minstrel-cue-sheets" />
                    </label>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Icon</span>
                        <input type="text" id="cue-icon" value="{{selectedCue.icon}}" placeholder="fa-solid fa-bell" />
                    </label>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Track</span>
                        <select id="cue-track">
                            <option value="">Select a track</option>
                            {{#each cueTrackOptions}}
                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </label>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Tint</span>
                        <input type="color" id="cue-tint-color" value="{{selectedCue.tintColor}}" />
                    </label>
                    <div class="minstrel-field">
                        <span class="minstrel-field-label">Volume</span>
                        <label class="minstrel-layer-slider" title="Volume" aria-label="Volume">
                            <input type="range" id="cue-volume" min="0" max="100" step="1" value="{{selectedCueVolumePercent}}" />
                            <span>{{selectedCueVolumePercent}}%</span>
                        </label>
                    </div>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Cooldown</span>
                        <input type="number" id="cue-cooldown" min="0" max="120" step="1" value="{{selectedCue.cooldown}}" />
                    </label>
                </div>
            </div>
            <datalist id="minstrel-cue-sheets">
                {{#each cueSheets}}
                <option value="{{this}}"></option>
                {{/each}}
            </datalist>
        </article>
    </section>
    {{/if}}

    {{#if isAutomation}}
    <section class="minstrel-cues-workspace">
        <article class="minstrel-panel-card minstrel-cues-browser-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Automation Rules</h3>
                <button type="button" class="minstrel-icon-action" data-action="newRule" title="New Rule" aria-label="New Rule"><i class="fa-solid fa-plus"></i></button>
            </header>
            <div class="minstrel-column-list">
                {{#each rules}}
                <div class="minstrel-list-row minstrel-automation-card {{#if this.isSelected}}is-selected{{/if}}">
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.eventLabel}} · Priority {{this.priority}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-icon-action" data-action="runRule" data-value="{{this.id}}" title="Run Rule" aria-label="Run Rule"><i class="fa-solid fa-play"></i></button>
                        <button type="button" class="minstrel-icon-action {{#if this.isSelected}}is-active{{/if}}" data-action="selectRule" data-value="{{this.id}}" title="Edit Rule" aria-label="Edit Rule"><i class="fa-solid fa-feather-pointed"></i></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No automation rules saved yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card minstrel-cue-editor-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Rule Editor</h3>
                <div class="minstrel-row-actions">
                    <label class="minstrel-icon-toggle" title="Restore previous audio on combat end">
                        <input type="checkbox" id="rule-restore" {{#if selectedRule.restorePreviousOnExit}}checked{{/if}} />
                        <i class="fa-solid fa-rotate-left"></i>
                    </label>
                    <label class="minstrel-icon-toggle" title="Rule enabled">
                        <input type="checkbox" id="rule-enabled" {{#if selectedRule.enabled}}checked{{/if}} />
                        <i class="fa-solid fa-power-off"></i>
                    </label>
                    <button type="button" class="minstrel-icon-action" data-action="saveRule" title="Save Rule" aria-label="Save Rule"><i class="fa-solid fa-floppy-disk"></i></button>
                    <button type="button" class="minstrel-icon-action" data-action="runRule" title="Run Rule" aria-label="Run Rule"><i class="fa-solid fa-play"></i></button>
                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="deleteRule" title="Delete Rule" aria-label="Delete Rule"><i class="fa-solid fa-trash"></i></button>
                </div>
            </header>
            <div class="minstrel-cue-editor-shell">
                <div class="minstrel-cue-editor-hero minstrel-automation-editor-hero">
                    <div class="minstrel-cue-editor-icon">
                        <i class="fa-solid fa-diagram-project"></i>
                    </div>
                    <div class="minstrel-cue-editor-copy">
                        <div class="minstrel-list-title">{{#if selectedRule.name}}{{selectedRule.name}}{{else}}New Rule{{/if}}</div>
                        <div class="minstrel-list-meta">{{selectedRule.eventType}}</div>
                    </div>
                </div>
                <div class="minstrel-form-grid minstrel-cue-form-grid">
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Rule Name</span>
                        <input type="text" id="rule-name" value="{{selectedRule.name}}" />
                    </label>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Event Type</span>
                        <select id="rule-event-type">
                            {{#each ruleEventOptions}}
                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </label>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Sound Scene</span>
                        <select id="rule-sound-scene">
                            <option value="">None</option>
                            {{#each ruleSoundSceneOptions}}
                            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
                            {{/each}}
                        </select>
                    </label>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Priority</span>
                        <input type="number" id="rule-priority" min="-100" max="100" step="1" value="{{selectedRule.priority}}" />
                    </label>
                    <label class="minstrel-field">
                        <span class="minstrel-field-label">Delay (ms)</span>
                        <input type="number" id="rule-delay-ms" min="0" max="30000" step="250" value="{{selectedRule.delayMs}}" />
                    </label>
                </div>
            </div>
        </article>
    </section>
    {{/if}}
</div>
