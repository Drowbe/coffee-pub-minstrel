<div class="minstrel-body">
    {{#if isDashboard}}
    <section class="minstrel-dashboard-workspace">
        <article class="minstrel-panel-card minstrel-dashboard-hero-card">
            <div class="minstrel-dashboard-hero-copy">
                <div class="minstrel-field-label">Session Control</div>
                <h2 class="minstrel-dashboard-hero-title">{{#if dashboard.activeSoundScene}}{{dashboard.activeSoundScene.name}}{{else if dashboard.nowPlaying.music}}{{dashboard.nowPlaying.music.soundName}}{{else}}Ready for Session{{/if}}</h2>
                <p class="minstrel-dashboard-hero-text">
                    {{#if dashboard.activeSoundScene}}
                    Active scene with {{dashboard.nowPlaying.activeTracks.length}} live layers.
                    {{else if dashboard.nowPlaying.activeTracks.length}}
                    {{dashboard.nowPlaying.activeTracks.length}} tracks currently playing.
                    {{else}}
                    Launch a favorite scene, trigger a cue, or resume a recent track.
                    {{/if}}
                </p>
                <div class="minstrel-tag-list">
                    {{#each dashboard.nowPlaying.activeTracks}}
                    <span class="minstrel-tag">{{this.soundName}}</span>
                    {{/each}}
                </div>
            </div>
            <div class="minstrel-dashboard-hero-actions">
                {{#if dashboard.activeSoundScene}}
                <button type="button" class="minstrel-dashboard-action" data-action="stopSoundScene" data-value="{{dashboard.activeSoundScene.id}}">
                    <i class="fa-solid fa-stop"></i>
                    <span>Stop Scene</span>
                </button>
                {{/if}}
                <button type="button" class="minstrel-dashboard-action" data-action="stopMusicLayer">
                    <i class="fa-solid fa-circle-stop"></i>
                    <span>Stop Music</span>
                </button>
                <button type="button" class="minstrel-dashboard-action" data-action="stopAmbientLayer">
                    <i class="fa-solid fa-wind"></i>
                    <span>Stop Environment</span>
                </button>
                <button type="button" class="minstrel-dashboard-action" data-action="stopAllAudio">
                    <i class="fa-solid fa-volume-xmark"></i>
                    <span>Stop All</span>
                </button>
            </div>
        </article>

        <div class="minstrel-dashboard-columns">
            <article class="minstrel-panel-card">
                <header class="minstrel-section-header">
                    <h3 class="minstrel-section-title">Favorite Scenes</h3>
                </header>
                <div class="minstrel-dashboard-card-grid">
                    {{#each dashboard.favoriteScenes}}
                    <div class="minstrel-dashboard-scene-card {{#if this.isActive}}minstrel-scene-browser-card-playing{{/if}}" {{#if this.backgroundImage}}style="background-image: linear-gradient(rgba(14, 10, 8, 0.7), rgba(14, 10, 8, 0.8)), url('{{this.backgroundImage}}');"{{/if}}>
                        <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                            <div class="minstrel-list-meta">{{this.layers.length}} tracks{{#if this.isActive}} · Playing{{/if}}</div>
                        </div>
                        <div class="minstrel-row-actions">
                            <button type="button" class="minstrel-icon-action {{#if this.isActive}}is-active{{/if}}" data-action="{{#if this.isActive}}stopSoundScene{{else}}playSoundScene{{/if}}" data-value="{{this.id}}" title="{{#if this.isActive}}Stop Scene{{else}}Play Scene{{/if}}" aria-label="{{#if this.isActive}}Stop Scene{{else}}Play Scene{{/if}}"><i class="fa-solid {{#if this.isActive}}fa-stop{{else}}fa-play{{/if}}"></i></button>
                        </div>
                    </div>
                    {{else}}
                    <p class="minstrel-empty">No favorite scenes saved yet.</p>
                    {{/each}}
                </div>
            </article>

            <article class="minstrel-panel-card">
                <header class="minstrel-section-header">
                    <h3 class="minstrel-section-title">Cue Rack</h3>
                </header>
                <div class="minstrel-dashboard-card-grid">
                    {{#each dashboard.favoriteCues}}
                    <button type="button" class="minstrel-cue-card" data-action="triggerCue" data-value="{{this.id}}">
                        <i class="{{this.icon}}"></i>
                        <span>{{this.name}}</span>
                        <small>{{this.category}}</small>
                    </button>
                    {{else}}
                    {{#each dashboard.recentCues}}
                    <button type="button" class="minstrel-cue-card" data-action="triggerCue" data-value="{{this.id}}">
                        <i class="{{this.icon}}"></i>
                        <span>{{this.name}}</span>
                        <small>{{this.category}}</small>
                    </button>
                    {{else}}
                    <p class="minstrel-empty">No favorite or recent cues yet.</p>
                    {{/each}}
                    {{/each}}
                </div>
            </article>

            <article class="minstrel-panel-card">
                <header class="minstrel-section-header">
                    <h3 class="minstrel-section-title">Quick Tracks</h3>
                </header>
                <div class="minstrel-list">
                    {{#each dashboard.favorites}}
                    <div class="minstrel-list-row">
                        <div>
                            <div class="minstrel-list-title">{{this.soundName}}</div>
                            <div class="minstrel-list-meta">{{this.playlistName}}</div>
                        </div>
                        <div class="minstrel-row-actions">
                            <button type="button" class="minstrel-icon-action" data-action="playTrack" data-value="{{this.playlistId}}::{{this.soundId}}" title="Play Track" aria-label="Play Track"><i class="fa-solid fa-play"></i></button>
                        </div>
                    </div>
                    {{else}}
                    <p class="minstrel-empty">No favorite tracks saved.</p>
                    {{/each}}
                </div>
            </article>

            <article class="minstrel-panel-card">
                <header class="minstrel-section-header">
                    <h3 class="minstrel-section-title">Prep Shelf</h3>
                </header>
                <div class="minstrel-list">
                    {{#each dashboard.recents}}
                    <div class="minstrel-list-row">
                        <div>
                            <div class="minstrel-list-title">{{this.soundName}}</div>
                            <div class="minstrel-list-meta">{{this.playlistName}}</div>
                        </div>
                        <div class="minstrel-row-actions">
                            <button type="button" class="minstrel-icon-action" data-action="playTrack" data-value="{{this.playlistId}}::{{this.soundId}}" title="Play Track" aria-label="Play Track"><i class="fa-solid fa-play"></i></button>
                        </div>
                    </div>
                    {{else}}
                    <p class="minstrel-empty">No recent tracks yet.</p>
                    {{/each}}
                </div>
            </article>
        </div>
    </section>
    {{/if}}

    {{#if isPlaylists}}
    <section class="minstrel-playlists-workspace">
        <article class="minstrel-panel-card minstrel-playlists-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Playlists</h3>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-icon-filter {{#if isPlaylistChannelAll}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="all" title="All channels" aria-label="All channels"><i class="fa-solid fa-layer-group"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isPlaylistChannelMusic}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="music" title="Music" aria-label="Music"><i class="fa-solid fa-music"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isPlaylistChannelAmbient}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="ambient" title="Environment" aria-label="Environment"><i class="fa-solid fa-wind"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isPlaylistChannelCue}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="cue" title="Interface" aria-label="Interface"><i class="fa-solid fa-bolt"></i></button>
                </div>
            </header>
            <div class="minstrel-column-controls minstrel-playlist-controls">
                <div class="minstrel-playlist-search-block">
                    <div class="minstrel-field-label">Search</div>
                    <div class="minstrel-playlist-search-row">
                        <div class="minstrel-search-input-wrap">
                            <input type="text" id="minstrel-playlist-search" class="minstrel-search-input" value="{{playlistSearch}}" placeholder="Search tracks, playlists, paths, and channels..." />
                            <button type="button" class="minstrel-search-clear" data-action="clearPlaylistFilters" title="Clear search" aria-label="Clear search"><i class="fa-solid fa-times"></i></button>
                        </div>
                        <div class="minstrel-filter-block minstrel-playlist-status-block">
                            <div class="minstrel-filter-row">
                            <button type="button" class="minstrel-icon-filter {{#if isPlaylistStatusAll}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="all" title="All results" aria-label="All results"><i class="fa-solid fa-list"></i></button>
                            <button type="button" class="minstrel-icon-filter {{#if isPlaylistStatusPlaying}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="playing" title="Playing" aria-label="Playing"><i class="fa-solid fa-play"></i></button>
                            <button type="button" class="minstrel-icon-filter {{#if isPlaylistStatusFavorites}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="favorites" title="Favorites" aria-label="Favorites"><i class="fa-solid fa-heart"></i></button>
                            <button type="button" class="minstrel-icon-filter {{#if isPlaylistStatusRecents}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="recents" title="Recents" aria-label="Recents"><i class="fa-solid fa-clock-rotate-left"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="minstrel-column-list minstrel-playlist-list">
                {{#each playlistSummary}}
                <section class="minstrel-playlist-group {{this.cardClass}}">
                    <header class="minstrel-playlist-group-header {{#if this.isActive}}minstrel-playlist-group-header-playing{{/if}}">
                        <div class="minstrel-selector-endcap" aria-hidden="true">
                            <i class="{{this.iconClass}}"></i>
                        </div>
                        <div class="minstrel-track-main">
                            <h3 class="minstrel-section-title">{{this.name}}</h3>
                            <div class="minstrel-list-meta">{{this.visualTypeLabel}} · {{this.playbackModeLabel}}{{#if this.isActive}} · Playing{{/if}}</div>
                        </div>
                        <div class="minstrel-row-actions">
                            <button type="button" class="minstrel-icon-action {{#if this.isActive}}is-active{{/if}}" data-action="playPlaylist" data-value="{{this.id}}" title="Play Playlist" aria-label="Play Playlist"><i class="fa-solid fa-play"></i></button>
                            <button type="button" class="minstrel-icon-action" data-action="stopPlaylist" data-value="{{this.id}}" title="Stop Playlist" aria-label="Stop Playlist"><i class="fa-solid fa-stop"></i></button>
                            <button type="button" class="minstrel-icon-filter {{#if this.favorite}}is-active{{/if}}" data-action="toggleFavoritePlaylist" data-value="{{this.id}}" title="{{#if this.favorite}}Unfavorite Playlist{{else}}Favorite Playlist{{/if}}" aria-label="{{#if this.favorite}}Unfavorite Playlist{{else}}Favorite Playlist{{/if}}"><i class="fa-solid fa-heart"></i></button>
                        </div>
                    </header>
                    <div class="minstrel-list">
                        {{#each this.sounds}}
                        <div class="minstrel-list-row minstrel-track-row {{this.cardClass}} {{#if this.playing}}minstrel-track-row-playing{{/if}}">
                            <div class="minstrel-selector-endcap" aria-hidden="true">
                                <i class="{{this.iconClass}}"></i>
                            </div>
                            <div class="minstrel-track-main">
                                <div class="minstrel-list-title">{{this.name}}</div>
                                <div class="minstrel-list-meta">{{this.statusLabel}} · {{this.channelLabel}} · {{this.path}}</div>
                            </div>
                            <div class="minstrel-row-actions minstrel-track-actions">
                                <div class="minstrel-inline-field minstrel-inline-field-volume">
                                    <label class="minstrel-layer-slider" title="Volume" aria-label="Volume">
                                        <i class="fa-solid fa-volume-high"></i>
                                        <input type="range" min="0" max="100" step="1" value="{{this.volumePercent}}" data-track-volume="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}" />
                                        <span>{{this.volumePercent}}%</span>
                                    </label>
                                </div>
                                <button type="button" class="minstrel-icon-action {{#if this.repeats}}is-active{{else}}is-inactive{{/if}}" data-action="toggleTrackRepeat" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}" title="{{this.repeatLabel}}" aria-label="{{this.repeatLabel}}"><i class="fa-solid fa-repeat"></i></button>
                                <button type="button" class="minstrel-icon-action {{#if this.playing}}is-active{{/if}}" data-action="{{#if this.playing}}stopTrack{{else}}playTrack{{/if}}" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}" title="{{#if this.playing}}Stop Track{{else}}Play Track{{/if}}" aria-label="{{#if this.playing}}Stop Track{{else}}Play Track{{/if}}"><i class="fa-solid {{#if this.playing}}fa-stop{{else}}fa-play{{/if}}"></i></button>
                                <button type="button" class="minstrel-icon-action {{#if this.favorite}}is-active{{/if}}" data-action="toggleFavoriteTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}" title="{{#if this.favorite}}Unfavorite Track{{else}}Favorite Track{{/if}}" aria-label="{{#if this.favorite}}Unfavorite Track{{else}}Favorite Track{{/if}}"><i class="fa-solid fa-heart"></i></button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </section>
                {{else}}
                <p class="minstrel-empty">No playlists match the current filters.</p>
                {{/each}}
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isSoundScenes}}
    <section class="minstrel-scenes-workspace">
        <article class="minstrel-panel-card minstrel-workspace-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Scenes</h3>
                <button type="button" class="minstrel-icon-action" data-action="newSoundScene" title="New Scene" aria-label="New Scene"><i class="fa-solid fa-rectangle-history-circle-plus"></i></button>
            </header>
            <div class="minstrel-column-controls">
                <div class="minstrel-search-input-wrap">
                    <input type="text" id="minstrel-scene-search" class="minstrel-search-input" value="{{sceneSearch}}" placeholder="Search scene..." />
                    <button type="button" class="minstrel-search-clear" data-action="clearSceneSearch" title="Clear search" aria-label="Clear search"><i class="fa-solid fa-times"></i></button>
                </div>
            </div>
                <div class="minstrel-column-list minstrel-list">
                {{#each filteredSoundScenes}}
                <div class="minstrel-list-row minstrel-scene-browser-card {{#if this.isActive}}minstrel-scene-browser-card-playing{{/if}}" data-action="selectSoundScene" data-value="{{this.id}}" role="button" tabindex="0" {{#if this.cardStyle}}style="{{this.cardStyle}}"{{/if}}>
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.layers.length}} tracks{{#if this.isActive}} · Playing{{/if}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-icon-action {{#if this.isActive}}is-active{{/if}}" data-action="{{#if this.isActive}}stopSoundScene{{else}}playSoundScene{{/if}}" data-value="{{this.id}}" data-tooltip="{{#if this.isActive}}Stop Scene{{else}}Play Scene{{/if}}" aria-label="{{#if this.isActive}}Stop Scene{{else}}Play Scene{{/if}}"><i class="fa-solid {{#if this.isActive}}fa-stop{{else}}fa-play{{/if}}"></i></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No sound scenes saved yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card minstrel-workspace-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Sound Selector</h3>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-icon-filter {{#if isSceneSoundFilterAll}}is-active{{/if}}" data-action="setSceneSoundFilter" data-value="all" title="All sounds" aria-label="All sounds"><i class="fa-solid fa-layer-group"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isSceneSoundFilterMusic}}is-active{{/if}}" data-action="setSceneSoundFilter" data-value="music" title="Music" aria-label="Music"><i class="fa-solid fa-music"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isSceneSoundFilterEnvironment}}is-active{{/if}}" data-action="setSceneSoundFilter" data-value="environment" title="Environment" aria-label="Environment"><i class="fa-solid fa-wind"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isSceneSoundFilterOneShot}}is-active{{/if}}" data-action="setSceneSoundFilter" data-value="scheduled-one-shot" title="Scheduled One-Shots" aria-label="Scheduled One-Shots"><i class="fa-solid fa-bolt"></i></button>
                </div>
            </header>
            <div class="minstrel-column-controls">
                <div class="minstrel-search-input-wrap">
                    <input type="text" id="minstrel-scene-sound-search" class="minstrel-search-input" value="{{sceneSoundSearch}}" placeholder="Search sounds..." />
                    <button type="button" class="minstrel-search-clear" data-action="clearSceneSoundSearch" title="Clear search" aria-label="Clear search"><i class="fa-solid fa-times"></i></button>
                </div>
            </div>
            <div class="minstrel-column-list">
                {{#each sceneSelectorOptions}}
                <div class="minstrel-selector-row {{this.cardClass}} {{#if this.isPreviewPlaying}}minstrel-selector-row-playing{{/if}}" data-action="previewSceneSelectorSound" data-value="{{this.value}}" role="button" tabindex="0">
                    <div class="minstrel-selector-endcap" aria-hidden="true">
                        <i class="{{this.iconClass}}"></i>
                    </div>
                    <div>
                        <div class="minstrel-list-title">{{this.soundName}}</div>
                        <div class="minstrel-list-meta">{{this.playlistName}}</div>
                    </div>
                    <button type="button" class="minstrel-icon-action" data-action="addSceneLayer" data-layer-type="{{this.layerType}}" data-value="{{this.value}}" title="Add Track to Scene" aria-label="Add Track to Scene"><i class="fa-solid fa-plus"></i></button>
                </div>
                {{else}}
                <p class="minstrel-empty">No matching sounds.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card minstrel-scene-editor-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Scene Details</h3>
                <div class="minstrel-row-actions">
                    <label class="minstrel-icon-toggle" title="Restore previous playback on exit">
                        <input type="checkbox" id="sound-scene-restore" {{#if selectedSoundScene.restorePreviousOnExit}}checked{{/if}} />
                        <i class="fa-solid fa-rotate-left"></i>
                    </label>
                    <label class="minstrel-icon-toggle" title="Scene enabled">
                        <input type="checkbox" id="sound-scene-enabled" {{#if selectedSoundScene.enabled}}checked{{/if}} />
                        <i class="fa-solid fa-power-off"></i>
                    </label>
                    <label class="minstrel-icon-toggle" title="Favorite scene">
                        <input type="checkbox" id="sound-scene-favorite" {{#if selectedSoundScene.favorite}}checked{{/if}} />
                        <i class="fa-solid fa-heart"></i>
                    </label>
                    <button type="button" class="minstrel-icon-action" data-action="saveSoundScene" title="Save Scene" aria-label="Save Scene"><i class="fa-solid fa-floppy-disk"></i></button>
                    <button type="button" class="minstrel-icon-action {{#if selectedSoundSceneIsActive}}is-active{{/if}}" data-action="{{#if selectedSoundSceneIsActive}}stopSoundScene{{else}}playSoundScene{{/if}}" data-value="{{selectedSoundScene.id}}" title="{{#if selectedSoundSceneIsActive}}Stop Scene{{else}}Play Scene{{/if}}" aria-label="{{#if selectedSoundSceneIsActive}}Stop Scene{{else}}Play Scene{{/if}}"><i class="fa-solid {{#if selectedSoundSceneIsActive}}fa-stop{{else}}fa-play{{/if}}"></i></button>
                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="deleteSoundScene" title="Delete Scene" aria-label="Delete Scene"><i class="fa-solid fa-trash"></i></button>
                </div>
            </header>
            <div class="minstrel-stack">
                <section class="minstrel-scene-hero {{#unless sceneDetailsEditMode}}minstrel-scene-hero-readonly{{/unless}}" {{#if sceneDetailsReadStyle}}style="{{sceneDetailsReadStyle}}"{{/if}}>
                    <div class="minstrel-scene-hero-header">
                        <button type="button" class="minstrel-icon-action {{#if sceneDetailsEditMode}}is-active{{/if}}" data-action="toggleSceneDetailsEditMode" title="{{#if sceneDetailsEditMode}}Finish Editing{{else}}Edit Scene Details{{/if}}" aria-label="{{#if sceneDetailsEditMode}}Finish Editing{{else}}Edit Scene Details{{/if}}">
                            <i class="fa-solid fa-feather-pointed"></i>
                        </button>
                    </div>
                    {{#if sceneDetailsEditMode}}
                    <div class="minstrel-scene-hero-grid">
                        <label class="minstrel-field minstrel-scene-field-title">
                            <span class="minstrel-field-label">Scene Name</span>
                            <input type="text" id="sound-scene-name" value="{{selectedSoundScene.name}}" />
                        </label>
                        <label class="minstrel-field minstrel-scene-field-image">
                            <span class="minstrel-field-label">Card Background</span>
                            <div class="minstrel-inline-field">
                                <input type="text" id="sound-scene-background-image" value="{{selectedSoundScene.backgroundImage}}" placeholder="Select an image for the scene card" />
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="browseSoundSceneBackground"><i class="fa-solid fa-image"></i><span>Browse</span></button>
                            </div>
                        </label>
                        <label class="minstrel-field minstrel-scene-field-tags">
                            <span class="minstrel-field-label">Tags</span>
                            <input type="text" id="sound-scene-tags" value="{{selectedSoundSceneTagText}}" placeholder="combat, tavern, rain" />
                        </label>
                        <div class="minstrel-stat-chip minstrel-scene-field-fadein">
                            <span class="minstrel-field-label">Fade In</span>
                            <input type="number" id="sound-scene-default-fade-in" min="0" max="30" step="1" value="{{selectedSoundScene.fadeIn}}" />
                        </div>
                        <div class="minstrel-stat-chip minstrel-scene-field-fadeout">
                            <span class="minstrel-field-label">Fade Out</span>
                            <input type="number" id="sound-scene-default-fade-out" min="0" max="30" step="1" value="{{selectedSoundScene.fadeOut}}" />
                        </div>
                        <label class="minstrel-field minstrel-form-span-2 minstrel-scene-field-description">
                            <span class="minstrel-field-label">Description</span>
                            <textarea id="sound-scene-description">{{selectedSoundScene.description}}</textarea>
                        </label>
                    </div>
                    {{else}}
                    <div class="minstrel-scene-hero-readonly-content">
                        <div class="minstrel-scene-hero-readonly-title">{{#if selectedSoundScene.name}}{{selectedSoundScene.name}}{{else}}Untitled Scene{{/if}}</div>
                        <div class="minstrel-scene-hero-readonly-meta">
                            <p><strong>Tags:</strong> {{#if selectedSoundSceneTagText}}{{selectedSoundSceneTagText}}{{else}}None{{/if}}</p>
                            <p><strong>Fade:</strong> {{selectedSoundScene.fadeIn}}s in / {{selectedSoundScene.fadeOut}}s out</p>
                        </div>
                        <div class="minstrel-scene-hero-readonly-description">
                            <p>{{#if selectedSoundScene.description}}{{selectedSoundScene.description}}{{else}}No description{{/if}}</p>
                        </div>
                    </div>
                    {{/if}}
                </section>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">Music</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneMusicLayers}}
                        <div class="minstrel-layer-card minstrel-card-music" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-row minstrel-layer-type-row">
                                <div class="minstrel-layer-type-icon" aria-hidden="true">
                                    <i class="fa-solid fa-music-note"></i>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-details">
                                    <div class="minstrel-layer-main">
                                        <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                        <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-audio">
                                    <label class="minstrel-layer-slider" title="Volume" aria-label="Volume">
                                        <i class="fa-solid fa-volume-high"></i>
                                        <input type="range" min="0" max="100" step="1" value="{{this.volumePercent}}" data-scene-layer-field="volume" />
                                        <span>{{this.volumePercent}}%</span>
                                    </label>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-timeline">
