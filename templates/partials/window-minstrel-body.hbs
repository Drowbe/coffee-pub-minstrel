<div class="minstrel-body">
    {{#if isDashboard}}
    <section class="minstrel-grid minstrel-dashboard-grid">
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Now Playing</h3>
            </header>
            <div class="minstrel-state-list">
                <div class="minstrel-state-row">
                    <span class="minstrel-state-label">Active Scene</span>
                    <span class="minstrel-state-value">{{#if dashboard.activeSoundScene}}{{dashboard.activeSoundScene.name}}{{else}}None{{/if}}</span>
                </div>
                <div class="minstrel-state-row">
                    <span class="minstrel-state-label">Music</span>
                    <span class="minstrel-state-value">{{#if dashboard.nowPlaying.music}}{{dashboard.nowPlaying.music.soundName}}{{else}}None{{/if}}</span>
                </div>
                <div class="minstrel-state-row">
                    <span class="minstrel-state-label">Ambient Layers</span>
                    <span class="minstrel-state-value">{{dashboard.nowPlaying.ambientTracks.length}}</span>
                </div>
            </div>
            <div class="minstrel-tag-list">
                {{#each dashboard.nowPlaying.activeTracks}}
                <span class="minstrel-tag">{{this.soundName}}</span>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Recent Tracks</h3>
            </header>
            <div class="minstrel-list">
                {{#each dashboard.recents}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.soundName}}</div>
                        <div class="minstrel-list-meta">{{this.playlistName}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="playTrack" data-value="{{this.playlistId}}::{{this.soundId}}"><i class="fa-solid fa-play"></i><span>Play</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No recent tracks yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Favorite Tracks</h3>
            </header>
            <div class="minstrel-list">
                {{#each dashboard.favorites}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.soundName}}</div>
                        <div class="minstrel-list-meta">{{this.playlistName}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="playTrack" data-value="{{this.playlistId}}::{{this.soundId}}"><i class="fa-solid fa-play"></i><span>Play</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No favorite tracks saved.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Recent Cues</h3>
            </header>
            <div class="minstrel-list">
                {{#each dashboard.recentCues}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.category}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="triggerCue" data-value="{{this.id}}"><i class="{{this.icon}}"></i><span>Trigger</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No cues triggered in this session.</p>
                {{/each}}
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isPlaylists}}
    <section class="minstrel-playlists-workspace">
        <article class="minstrel-panel-card minstrel-playlists-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Playlists</h3>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-icon-filter {{#if isPlaylistChannelAll}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="all" title="All channels" aria-label="All channels"><i class="fa-solid fa-layer-group"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isPlaylistChannelMusic}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="music" title="Music" aria-label="Music"><i class="fa-solid fa-music"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isPlaylistChannelAmbient}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="ambient" title="Environment" aria-label="Environment"><i class="fa-solid fa-wind"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isPlaylistChannelCue}}is-active{{/if}}" data-action="setPlaylistChannelFilter" data-value="cue" title="Interface" aria-label="Interface"><i class="fa-solid fa-bolt"></i></button>
                </div>
            </header>
            <div class="minstrel-column-controls minstrel-playlist-controls">
                <div class="minstrel-playlist-search-block">
                    <div class="minstrel-field-label">Search</div>
                    <div class="minstrel-playlist-search-row">
                        <div class="minstrel-search-input-wrap">
                            <input type="text" id="minstrel-playlist-search" class="minstrel-search-input" value="{{playlistSearch}}" placeholder="Search tracks, playlists, paths, and channels..." />
                            <button type="button" class="minstrel-search-clear" data-action="clearPlaylistFilters" title="Clear search" aria-label="Clear search"><i class="fa-solid fa-times"></i></button>
                        </div>
                        <div class="minstrel-filter-block minstrel-playlist-status-block">
                            <div class="minstrel-filter-row">
                            <button type="button" class="minstrel-icon-filter {{#if isPlaylistStatusAll}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="all" title="All results" aria-label="All results"><i class="fa-solid fa-list"></i></button>
                            <button type="button" class="minstrel-icon-filter {{#if isPlaylistStatusPlaying}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="playing" title="Playing" aria-label="Playing"><i class="fa-solid fa-play"></i></button>
                            <button type="button" class="minstrel-icon-filter {{#if isPlaylistStatusFavorites}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="favorites" title="Favorites" aria-label="Favorites"><i class="fa-solid fa-heart"></i></button>
                            <button type="button" class="minstrel-icon-filter {{#if isPlaylistStatusRecents}}is-active{{/if}}" data-action="setPlaylistStatusFilter" data-value="recents" title="Recents" aria-label="Recents"><i class="fa-solid fa-clock-rotate-left"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="minstrel-column-list minstrel-playlist-list">
                {{#each playlistSummary}}
                <section class="minstrel-playlist-group {{this.cardClass}}">
                    <header class="minstrel-playlist-group-header">
                        <div class="minstrel-selector-endcap" aria-hidden="true">
                            <i class="{{this.iconClass}}"></i>
                        </div>
                        <h3 class="minstrel-section-title">{{this.name}}</h3>
                        <div class="minstrel-row-actions">
                            <button type="button" class="minstrel-icon-filter {{#if this.favorite}}is-active{{/if}}" data-action="toggleFavoritePlaylist" data-value="{{this.id}}" title="{{#if this.favorite}}Unfavorite Playlist{{else}}Favorite Playlist{{/if}}" aria-label="{{#if this.favorite}}Unfavorite Playlist{{else}}Favorite Playlist{{/if}}"><i class="fa-solid fa-heart"></i></button>
                            <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="skipPlaylist" data-value="{{this.id}}"><i class="fa-solid fa-forward-step"></i><span>Skip</span></button>
                        </div>
                    </header>
                    <div class="minstrel-list">
                        {{#each this.sounds}}
                        <div class="minstrel-list-row minstrel-track-row {{this.cardClass}}">
                            <div class="minstrel-selector-endcap" aria-hidden="true">
                                <i class="{{this.iconClass}}"></i>
                            </div>
                            <div class="minstrel-track-main">
                                <div class="minstrel-list-title">{{this.name}}</div>
                                <div class="minstrel-list-meta">{{#if this.playing}}Playing{{else}}Idle{{/if}} · {{this.channel}} · {{this.path}}</div>
                            </div>
                            <div class="minstrel-inline-field minstrel-inline-field-volume">
                                <span class="minstrel-field-label">Vol</span>
                                <input type="number" min="0" max="1" step="0.05" value="{{this.volume}}" data-track-volume="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}" />
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="applyTrackVolume" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-sliders"></i><span>Apply</span></button>
                            </div>
                            <div class="minstrel-row-actions minstrel-track-actions">
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="playTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-play"></i><span>Play</span></button>
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="pauseTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-pause"></i><span>Pause</span></button>
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="resumeTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-play-circle"></i><span>Resume</span></button>
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="stopTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid fa-stop"></i><span>Stop</span></button>
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="toggleFavoriteTrack" data-value="{{this.trackRef.playlistId}}::{{this.trackRef.soundId}}"><i class="fa-solid {{#if this.favorite}}fa-heart{{else}}fa-heart-crack{{/if}}"></i><span>{{#if this.favorite}}Unfavorite{{else}}Favorite{{/if}}</span></button>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </section>
                {{else}}
                <p class="minstrel-empty">No playlists match the current filters.</p>
                {{/each}}
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isSoundScenes}}
    <section class="minstrel-scenes-workspace">
        <article class="minstrel-panel-card minstrel-workspace-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Scenes</h3>
                <button type="button" class="minstrel-icon-action" data-action="newSoundScene" title="New Scene" aria-label="New Scene"><i class="fa-solid fa-rectangle-history-circle-plus"></i></button>
            </header>
            <div class="minstrel-column-controls">
                <div class="minstrel-search-input-wrap">
                    <input type="text" id="minstrel-scene-search" class="minstrel-search-input" value="{{sceneSearch}}" placeholder="Search scene..." />
                    <button type="button" class="minstrel-search-clear" data-action="clearSceneSearch" title="Clear search" aria-label="Clear search"><i class="fa-solid fa-times"></i></button>
                </div>
            </div>
            <div class="minstrel-column-list minstrel-list">
                {{#each filteredSoundScenes}}
                <div class="minstrel-list-row minstrel-scene-browser-card" data-action="selectSoundScene" data-value="{{this.id}}" role="button" tabindex="0" {{#if this.cardStyle}}style="{{this.cardStyle}}"{{/if}}>
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.layers.length}} layers</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-icon-action" data-action="playSoundScene" data-value="{{this.id}}" data-tooltip="Play Scene" aria-label="Play Scene"><i class="fa-solid fa-play"></i></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No sound scenes saved yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card minstrel-workspace-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Sound Selector</h3>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-icon-filter {{#if isSceneSoundFilterAll}}is-active{{/if}}" data-action="setSceneSoundFilter" data-value="all" title="All sounds" aria-label="All sounds"><i class="fa-solid fa-layer-group"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isSceneSoundFilterMusic}}is-active{{/if}}" data-action="setSceneSoundFilter" data-value="music" title="Music" aria-label="Music"><i class="fa-solid fa-music"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isSceneSoundFilterEnvironment}}is-active{{/if}}" data-action="setSceneSoundFilter" data-value="environment" title="Environment" aria-label="Environment"><i class="fa-solid fa-wind"></i></button>
                    <button type="button" class="minstrel-icon-filter {{#if isSceneSoundFilterOneShot}}is-active{{/if}}" data-action="setSceneSoundFilter" data-value="scheduled-one-shot" title="Scheduled One-Shots" aria-label="Scheduled One-Shots"><i class="fa-solid fa-bolt"></i></button>
                </div>
            </header>
            <div class="minstrel-column-controls">
                <div class="minstrel-search-input-wrap">
                    <input type="text" id="minstrel-scene-sound-search" class="minstrel-search-input" value="{{sceneSoundSearch}}" placeholder="Search sounds..." />
                    <button type="button" class="minstrel-search-clear" data-action="clearSceneSoundSearch" title="Clear search" aria-label="Clear search"><i class="fa-solid fa-times"></i></button>
                </div>
            </div>
            <div class="minstrel-column-list">
                {{#each sceneSelectorOptions}}
                <div class="minstrel-selector-row {{this.cardClass}} {{#if this.isPreviewPlaying}}minstrel-selector-row-playing{{/if}}" data-action="previewSceneSelectorSound" data-value="{{this.value}}" role="button" tabindex="0">
                    <div class="minstrel-selector-endcap" aria-hidden="true">
                        <i class="{{this.iconClass}}"></i>
                    </div>
                    <div>
                        <div class="minstrel-list-title">{{this.soundName}}</div>
                        <div class="minstrel-list-meta">{{this.playlistName}}</div>
                    </div>
                    <button type="button" class="minstrel-icon-action" data-action="addSceneLayer" data-layer-type="{{this.layerType}}" data-value="{{this.value}}" title="Add to Scene" aria-label="Add to Scene"><i class="fa-solid fa-plus"></i></button>
                </div>
                {{else}}
                <p class="minstrel-empty">No matching sounds.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card minstrel-scene-editor-column">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Scene Details</h3>
                <div class="minstrel-row-actions">
                    <label class="minstrel-icon-toggle" title="Restore previous playback on exit">
                        <input type="checkbox" id="sound-scene-restore" {{#if selectedSoundScene.restorePreviousOnExit}}checked{{/if}} />
                        <i class="fa-solid fa-rotate-left"></i>
                    </label>
                    <label class="minstrel-icon-toggle" title="Scene enabled">
                        <input type="checkbox" id="sound-scene-enabled" {{#if selectedSoundScene.enabled}}checked{{/if}} />
                        <i class="fa-solid fa-power-off"></i>
                    </label>
                    <label class="minstrel-icon-toggle" title="Favorite scene">
                        <input type="checkbox" id="sound-scene-favorite" {{#if selectedSoundScene.favorite}}checked{{/if}} />
                        <i class="fa-solid fa-heart"></i>
                    </label>
                    <button type="button" class="minstrel-icon-action" data-action="saveSoundScene" title="Save Scene" aria-label="Save Scene"><i class="fa-solid fa-floppy-disk"></i></button>
                    <button type="button" class="minstrel-icon-action" data-action="playSoundScene" data-value="{{selectedSoundScene.id}}" title="Play Scene" aria-label="Play Scene"><i class="fa-solid fa-play"></i></button>
                    <button type="button" class="minstrel-icon-action" data-action="stopSoundScene" title="Stop Scene" aria-label="Stop Scene"><i class="fa-solid fa-stop"></i></button>
                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="deleteSoundScene" title="Delete Scene" aria-label="Delete Scene"><i class="fa-solid fa-trash"></i></button>
                </div>
            </header>
            <div class="minstrel-stack">
                <section class="minstrel-scene-hero">
                    <div class="minstrel-scene-hero-grid">
                        <label class="minstrel-field minstrel-scene-field-title">
                            <span class="minstrel-field-label">Scene Name</span>
                            <input type="text" id="sound-scene-name" value="{{selectedSoundScene.name}}" />
                        </label>
                        <label class="minstrel-field minstrel-scene-field-image">
                            <span class="minstrel-field-label">Card Background</span>
                            <div class="minstrel-inline-field">
                                <input type="text" id="sound-scene-background-image" value="{{selectedSoundScene.backgroundImage}}" placeholder="Select an image for the scene card" />
                                <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="browseSoundSceneBackground"><i class="fa-solid fa-image"></i><span>Browse</span></button>
                            </div>
                        </label>
                        <label class="minstrel-field minstrel-scene-field-tags">
                            <span class="minstrel-field-label">Tags</span>
                            <input type="text" id="sound-scene-tags" value="{{selectedSoundSceneTagText}}" placeholder="combat, tavern, rain" />
                        </label>
                        <div class="minstrel-stat-chip minstrel-scene-field-fadein">
                            <span class="minstrel-field-label">Fade In</span>
                            <input type="number" id="sound-scene-default-fade-in" min="0" max="30" step="1" value="{{selectedSoundScene.fadeIn}}" />
                        </div>
                        <div class="minstrel-stat-chip minstrel-scene-field-fadeout">
                            <span class="minstrel-field-label">Fade Out</span>
                            <input type="number" id="sound-scene-default-fade-out" min="0" max="30" step="1" value="{{selectedSoundScene.fadeOut}}" />
                        </div>
                        <label class="minstrel-field minstrel-form-span-2 minstrel-scene-field-description">
                            <span class="minstrel-field-label">Description</span>
                            <textarea id="sound-scene-description">{{selectedSoundScene.description}}</textarea>
                        </label>
                    </div>
                </section>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">Music</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneMusicLayers}}
                        <div class="minstrel-layer-card minstrel-card-music" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-row minstrel-layer-type-row">
                                <div class="minstrel-layer-type-icon" aria-hidden="true">
                                    <i class="fa-solid fa-music-note"></i>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-details">
                                    <div class="minstrel-layer-main">
                                        <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                        <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-audio">
                                    <label class="minstrel-layer-slider" title="Volume" aria-label="Volume">
                                        <i class="fa-solid fa-volume-high"></i>
                                        <input type="range" min="0" max="100" step="1" value="{{this.volumePercent}}" data-scene-layer-field="volume" />
                                        <span>{{this.volumePercent}}%</span>
                                    </label>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-timeline">
                                    <div class="minstrel-layer-timeline-slot {{#if this.timelineIsActive}}is-active{{/if}} {{#if this.timelineSingleEvent}}is-event-only{{/if}}" title="{{this.timelineTooltip}}">
                                        <span class="minstrel-layer-timeline-start-marker"></span>
                                        {{#if this.timelineShowBar}}
                                        <div class="minstrel-layer-timeline-bar" style="width: {{this.timelineWidthPercent}}%;"></div>
                                        {{/if}}
                                        {{#each this.timelineRepeatSegments}}
                                        <div class="minstrel-layer-timeline-repeat-bar" style="left: {{this.leftPercent}}%; width: {{this.widthPercent}}%;"></div>
                                        {{/each}}
                                        {{#if this.timelineSingleEvent}}
                                        <span class="minstrel-layer-timeline-event-marker"></span>
                                        {{/if}}
                                        {{#each this.timelineRepeatMarkers}}
                                        <span class="minstrel-layer-timeline-repeat-marker" style="left: {{this}}%;"></span>
                                        {{/each}}
                                        <span class="minstrel-layer-timeline-label">{{this.durationLabel}}</span>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-actions">
                                    <div class="minstrel-layer-controls">
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Loop playback">
                                        <input type="checkbox" data-scene-layer-field="loopMode" {{#if this.loopEnabled}}checked{{/if}} />
                                        <i class="fa-solid fa-repeat"></i>
                                    </label>
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Layer enabled">
                                        <input type="checkbox" data-scene-layer-field="enabled" {{#if this.enabled}}checked{{/if}} />
                                        <i class="fa-solid fa-power-off"></i>
                                    </label>
                                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="removeSceneLayer" data-value="{{this.id}}" title="Remove layer" aria-label="Remove layer"><i class="fa-solid fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No music layer yet.</p>
                        {{/each}}
                    </div>
                </div>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">Environment</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneEnvironmentLayers}}
                        <div class="minstrel-layer-card minstrel-card-environment" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-row minstrel-layer-type-row">
                                <div class="minstrel-layer-type-icon" aria-hidden="true">
                                    <i class="fa-solid fa-waveform"></i>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-details">
                                    <div class="minstrel-layer-main">
                                        <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                        <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-audio">
                                    <label class="minstrel-layer-slider" title="Volume" aria-label="Volume">
                                        <i class="fa-solid fa-volume-high"></i>
                                        <input type="range" min="0" max="100" step="1" value="{{this.volumePercent}}" data-scene-layer-field="volume" />
                                        <span>{{this.volumePercent}}%</span>
                                    </label>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-timeline">
                                    <div class="minstrel-layer-timeline-slot {{#if this.timelineIsActive}}is-active{{/if}} {{#if this.timelineSingleEvent}}is-event-only{{/if}}" title="{{this.timelineTooltip}}">
                                        <span class="minstrel-layer-timeline-start-marker"></span>
                                        {{#if this.timelineShowBar}}
                                        <div class="minstrel-layer-timeline-bar" style="width: {{this.timelineWidthPercent}}%;"></div>
                                        {{/if}}
                                        {{#each this.timelineRepeatSegments}}
                                        <div class="minstrel-layer-timeline-repeat-bar" style="left: {{this.leftPercent}}%; width: {{this.widthPercent}}%;"></div>
                                        {{/each}}
                                        {{#if this.timelineSingleEvent}}
                                        <span class="minstrel-layer-timeline-event-marker"></span>
                                        {{/if}}
                                        {{#each this.timelineRepeatMarkers}}
                                        <span class="minstrel-layer-timeline-repeat-marker" style="left: {{this}}%;"></span>
                                        {{/each}}
                                        <span class="minstrel-layer-timeline-label">{{this.durationLabel}}</span>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-actions">
                                    <div class="minstrel-layer-controls">
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Loop playback">
                                        <input type="checkbox" data-scene-layer-field="loopMode" {{#if this.loopEnabled}}checked{{/if}} />
                                        <i class="fa-solid fa-repeat"></i>
                                    </label>
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Layer enabled">
                                        <input type="checkbox" data-scene-layer-field="enabled" {{#if this.enabled}}checked{{/if}} />
                                        <i class="fa-solid fa-power-off"></i>
                                    </label>
                                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="removeSceneLayer" data-value="{{this.id}}" title="Remove layer" aria-label="Remove layer"><i class="fa-solid fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No environment layers yet.</p>
                        {{/each}}
                    </div>
                </div>

                <div class="minstrel-layer-section">
                    <div class="minstrel-subheader">One-Shots</div>
                    <div class="minstrel-layer-stack">
                        {{#each selectedSceneScheduledLayers}}
                        <div class="minstrel-layer-card minstrel-card-oneshot" data-scene-layer-row data-layer-id="{{this.id}}" data-layer-type="{{this.type}}" data-track-value="{{this.trackValue}}">
                            <div class="minstrel-layer-row minstrel-layer-type-row">
                                <div class="minstrel-layer-type-icon" aria-hidden="true">
                                    <i class="fa-solid fa-volume"></i>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-details">
                                    <div class="minstrel-layer-main">
                                        <div class="minstrel-list-title">{{this.trackRef.soundName}}</div>
                                        <div class="minstrel-list-meta">{{this.trackRef.playlistName}}</div>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-audio">
                                    <label class="minstrel-layer-slider" title="Volume" aria-label="Volume">
                                        <i class="fa-solid fa-volume-high"></i>
                                        <input type="range" min="0" max="100" step="1" value="{{this.volumePercent}}" data-scene-layer-field="volume" />
                                        <span>{{this.volumePercent}}%</span>
                                    </label>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-timeline">
                                    <div class="minstrel-layer-timeline-slot {{#if this.timelineIsActive}}is-active{{/if}} {{#if this.timelineSingleEvent}}is-event-only{{/if}}" title="{{this.timelineTooltip}}">
                                        <span class="minstrel-layer-timeline-start-marker"></span>
                                        {{#if this.timelineShowBar}}
                                        <div class="minstrel-layer-timeline-bar" style="width: {{this.timelineWidthPercent}}%;"></div>
                                        {{/if}}
                                        {{#each this.timelineRepeatSegments}}
                                        <div class="minstrel-layer-timeline-repeat-bar" style="left: {{this.leftPercent}}%; width: {{this.widthPercent}}%;"></div>
                                        {{/each}}
                                        {{#if this.timelineSingleEvent}}
                                        <span class="minstrel-layer-timeline-event-marker"></span>
                                        {{/if}}
                                        {{#each this.timelineRepeatMarkers}}
                                        <span class="minstrel-layer-timeline-repeat-marker" style="left: {{this}}%;"></span>
                                        {{/each}}
                                        <span class="minstrel-layer-timeline-label">{{this.durationLabel}}</span>
                                    </div>
                                </div>
                                <div class="minstrel-layer-zone minstrel-layer-zone-actions">
                                    <div class="minstrel-layer-controls">
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Loop playback">
                                        <input type="checkbox" data-scene-layer-field="loopMode" {{#if this.loopEnabled}}checked{{/if}} />
                                        <i class="fa-solid fa-repeat"></i>
                                    </label>
                                    <label class="minstrel-layer-textfield {{#unless this.loopEnabled}}is-hidden{{/unless}}" data-scene-layer-frequency title="Frequency in seconds" aria-label="Frequency in seconds">
                                        <input type="number" min="1" max="3600" step="1" value="{{this.frequencySeconds}}" data-scene-layer-field="frequencySeconds" />
                                    </label>
                                    <label class="minstrel-icon-toggle minstrel-icon-toggle-inline" title="Layer enabled">
                                        <input type="checkbox" data-scene-layer-field="enabled" {{#if this.enabled}}checked{{/if}} />
                                        <i class="fa-solid fa-power-off"></i>
                                    </label>
                                    <button type="button" class="minstrel-icon-action minstrel-icon-action-danger" data-action="removeSceneLayer" data-value="{{this.id}}" title="Remove layer" aria-label="Remove layer"><i class="fa-solid fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{else}}
                        <p class="minstrel-empty">No scheduled one-shots yet.</p>
                        {{/each}}
                    </div>
                </div>
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isCues}}
    <section class="minstrel-editor-grid">
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Cues</h3>
                <button type="button" class="minstrel-btn minstrel-btn-icononly blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="newCue" title="New Cue" aria-label="New Cue"><i class="fa-solid fa-plus"></i><span>New</span></button>
            </header>
            <div class="minstrel-cue-grid">
                {{#each cues}}
                <button type="button" class="minstrel-cue-card" data-action="triggerCue" data-value="{{this.id}}">
                    <i class="{{this.icon}}"></i>
                    <span>{{this.name}}</span>
                </button>
                {{else}}
                <p class="minstrel-empty">No cues configured yet.</p>
                {{/each}}
            </div>
            <div class="minstrel-list">
                {{#each cues}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.category}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="selectCue" data-value="{{this.id}}"><i class="fa-solid fa-pen"></i><span>Edit</span></button>
                    </div>
                </div>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Cue Editor</h3>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="saveCue"><i class="fa-solid fa-floppy-disk"></i><span>Save</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="triggerCue"><i class="fa-solid fa-bolt"></i><span>Trigger</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-danger" data-action="deleteCue"><i class="fa-solid fa-trash"></i><span>Delete</span></button>
                </div>
            </header>
            <div class="minstrel-form-grid">
                <label>Name<input type="text" id="cue-name" value="{{selectedCue.name}}" /></label>
                <label>Category<input type="text" id="cue-category" value="{{selectedCue.category}}" /></label>
                <label>Icon<input type="text" id="cue-icon" value="{{selectedCue.icon}}" placeholder="fa-solid fa-bell" /></label>
                <label>Track
                    <select id="cue-track">
                        <option value="">Select a track</option>
                        {{#each cueTrackOptions}}
                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                        {{/each}}
                    </select>
                </label>
                <label>Volume<input type="number" id="cue-volume" min="0" max="1" step="0.05" value="{{selectedCue.volume}}" /></label>
                <label>Cooldown (seconds)<input type="number" id="cue-cooldown" min="0" max="120" step="1" value="{{selectedCue.cooldown}}" /></label>
                <label class="minstrel-checkbox"><input type="checkbox" id="cue-duck-others" {{#if selectedCue.duckOthers}}checked{{/if}} /> Duck music and ambience</label>
                <label class="minstrel-checkbox"><input type="checkbox" id="cue-stop-on-scene-change" {{#if selectedCue.stopOnSceneChange}}checked{{/if}} /> Stop on scene change</label>
                <label class="minstrel-checkbox"><input type="checkbox" id="cue-favorite" {{#if selectedCue.favorite}}checked{{/if}} /> Favorite</label>
                <label class="minstrel-checkbox"><input type="checkbox" id="cue-enabled" {{#if selectedCue.enabled}}checked{{/if}} /> Enabled</label>
            </div>
        </article>
    </section>
    {{/if}}

    {{#if isAutomation}}
    <section class="minstrel-editor-grid">
        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Automation Rules</h3>
                <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="newRule"><i class="fa-solid fa-plus"></i><span>New</span></button>
            </header>
            <div class="minstrel-list">
                {{#each rules}}
                <div class="minstrel-list-row">
                    <div>
                        <div class="minstrel-list-title">{{this.name}}</div>
                        <div class="minstrel-list-meta">{{this.eventType}} · Priority {{this.priority}}</div>
                    </div>
                    <div class="minstrel-row-actions">
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="selectRule" data-value="{{this.id}}"><i class="fa-solid fa-pen"></i><span>Edit</span></button>
                        <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="runRule" data-value="{{this.id}}"><i class="fa-solid fa-play"></i><span>Run</span></button>
                    </div>
                </div>
                {{else}}
                <p class="minstrel-empty">No automation rules saved yet.</p>
                {{/each}}
            </div>
        </article>

        <article class="minstrel-panel-card">
            <header class="minstrel-section-header">
                <h3 class="minstrel-section-title">Rule Editor</h3>
                <div class="minstrel-row-actions">
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-primary minstrel-btn-primary" data-action="saveRule"><i class="fa-solid fa-floppy-disk"></i><span>Save</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-ghost" data-action="runRule"><i class="fa-solid fa-play"></i><span>Run</span></button>
                    <button type="button" class="minstrel-btn blacksmith-window-template-btn-secondary minstrel-btn-danger" data-action="deleteRule"><i class="fa-solid fa-trash"></i><span>Delete</span></button>
                </div>
            </header>
            <div class="minstrel-form-grid">
                <label>Name<input type="text" id="rule-name" value="{{selectedRule.name}}" /></label>
                <label>Event Type
                    <select id="rule-event-type">
                        {{#each ruleEventOptions}}
                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                        {{/each}}
                    </select>
                </label>
                <label>Sound Scene
                    <select id="rule-sound-scene">
                        <option value="">None</option>
                        {{#each ruleSoundSceneOptions}}
                        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
                        {{/each}}
                    </select>
                </label>
                <label>Priority<input type="number" id="rule-priority" min="-100" max="100" step="1" value="{{selectedRule.priority}}" /></label>
                <label>Delay (ms)<input type="number" id="rule-delay-ms" min="0" max="30000" step="250" value="{{selectedRule.delayMs}}" /></label>
                <label class="minstrel-checkbox"><input type="checkbox" id="rule-restore" {{#if selectedRule.restorePreviousOnExit}}checked{{/if}} /> Restore previous audio on combat end</label>
                <label class="minstrel-checkbox"><input type="checkbox" id="rule-enabled" {{#if selectedRule.enabled}}checked{{/if}} /> Enabled</label>
            </div>
        </article>
    </section>
    {{/if}}
</div>
